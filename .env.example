# ─────────────────────────────────────────────────────────────────────────────
# Nexis — Environment Configuration Example
# ─────────────────────────────────────────────────────────────────────────────
# This file is a template. Do NOT put real values here.
# Copy this file to public/config.js and fill in your actual values.
#
# Where to find these values:
#   1. Go to https://supabase.com and open your project
#   2. Navigate to: Project Settings → API
#   3. Copy "Project URL" → SUPABASE_URL
#   4. Copy "anon / public" key → SUPABASE_ANON_KEY
#
# The anon key is intentionally public-safe. It is scoped by Row Level
# Security (RLS) policies you configure in Supabase. Never use the
# service_role key in the browser.
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
